{
  "name": "rpandassociates-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env -o -- next dev",
    "build": "pnpm validate:data && next build",
    "start": "dotenv -e .env -o -- next start -p ${PORT:-3000}",
    "start:railway": "next start -p ${PORT:-3000}",
    "lint": "tsc --noEmit",
    "validate:data": "tsx scripts/validate-catalog.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.14.0",
    "next": "^14.2.0",
    "openai": "^6.25.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "resend": "^6.12.2",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "autoprefixer": "^10.5.0",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.0"
  }
}
